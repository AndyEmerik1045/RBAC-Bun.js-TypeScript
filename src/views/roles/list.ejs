<div class="bg-white rounded shadow p-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-bold text-gray-700">Daftar Roles</h2>
    <form method="POST" action="/roles" class="flex gap-2">
      <input type="text" name="name" placeholder="Nama Role" required
        class="border rounded px-3 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
      <button type="submit"
        class="bg-blue-600 text-white px-3 py-1 rounded text-sm hover:bg-blue-700">
        + Tambah
      </button>
    </form>
  </div>

  <table class="w-full table-auto border-collapse">
    <thead>
      <tr class="bg-gray-200 text-left text-sm">
        <th class="p-3">ID</th>
        <th class="p-3">Nama Role</th>
        <th class="p-3">Dibuat</th>
        <th class="p-3">Aksi</th>
      </tr>
    </thead>
    <tbody>
      <% roles.forEach(role => { %>
      <tr class="border-t hover:bg-gray-50 text-sm">
        <td class="p-3"><%= role.id %></td>
        <td class="p-3"><%= role.name %></td>
        <td class="p-3"><%= role.created_at %></td>
        <td class="p-3">
          <form method="POST" action="/roles/<%= role.id %>?_method=DELETE">
            <button type="submit"
              class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 text-sm">
              Hapus
            </button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
