<div class="bg-white rounded shadow p-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-bold text-gray-700">Daftar Permissions</h2>
    <form method="POST" action="/permissions/assign" class="flex gap-2">
      <select name="role_id" class="border rounded px-3 py-1 text-sm">
        <option value="1">Admin</option>
        <option value="2">Editor</option>
        <option value="3">Viewer</option>
      </select>
      <select name="permission_id" class="border rounded px-3 py-1 text-sm">
        <% permissions.forEach(p => { %>
          <option value="<%= p.id %>"><%= p.name %></option>
        <% }) %>
      </select>
      <button type="submit"
        class="bg-blue-600 text-white px-3 py-1 rounded text-sm hover:bg-blue-700">
        + Assign
      </button>
    </form>
  </div>

  <table class="w-full table-auto border-collapse">
    <thead>
      <tr class="bg-gray-200 text-left text-sm">
        <th class="p-3">ID</th>
        <th class="p-3">Nama Permission</th>
        <th class="p-3">Resource</th>
        <th class="p-3">Action</th>
      </tr>
    </thead>
    <tbody>
      <% permissions.forEach(p => { %>
      <tr class="border-t hover:bg-gray-50 text-sm">
        <td class="p-3"><%= p.id %></td>
        <td class="p-3"><%= p.name %></td>
        <td class="p-3"><%= p.resource %></td>
        <td class="p-3"><%= p.action %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
