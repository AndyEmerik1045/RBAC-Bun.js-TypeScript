<div class="bg-white rounded shadow p-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-bold text-gray-700">Daftar Users</h2>
    <form method="POST" action="/users" class="flex gap-2">
      <input type="text" name="username" placeholder="Username" required
        class="border rounded px-3 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
      <input type="password" name="password" placeholder="Password" required
        class="border rounded px-3 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
      <select name="role_id" class="border rounded px-3 py-1 text-sm">
        <option value="1">Admin</option>
        <option value="2">Editor</option>
        <option value="3">Viewer</option>
      </select>
      <button type="submit"
        class="bg-blue-600 text-white px-3 py-1 rounded text-sm hover:bg-blue-700">
        + Tambah
      </button>
    </form>
  </div>

  <table class="w-full table-auto border-collapse">
    <thead>
      <tr class="bg-gray-200 text-left text-sm">
        <th class="p-3">ID</th>
        <th class="p-3">Username</th>
        <th class="p-3">Role</th>
        <th class="p-3">Aksi</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(user => { %>
      <tr class="border-t hover:bg-gray-50 text-sm">
        <td class="p-3"><%= user.id %></td>
        <td class="p-3"><%= user.username %></td>
        <td class="p-3"><%= user.role_id %></td>
        <td class="p-3">
          <form method="POST" action="/users/<%= user.id %>?_method=DELETE">
            <button type="submit"
              class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600 text-sm">
              Hapus
            </button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
